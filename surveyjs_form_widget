<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SurveyJS Widget – Grist</title>

  <!-- SurveyJS -->
  <link href="https://unpkg.com/survey-core/survey-core.min.css" rel="stylesheet">
  <script src="https://unpkg.com/survey-core/survey.core.min.js"></script>
  <script src="https://unpkg.com/survey-js-ui/survey-js-ui.min.js"></script>

  <!-- Grist Plugin API -->
  <script src="https://docs.getgrist.com/grist-plugin-api.js"></script>

  <style>
/* ════════════════════════════════
   DESIGN TOKENS
════════════════════════════════ */
:root {
  --bg:        #f5f7fb;
  --surface:   #ffffff;
  --border:    #dde3f0;
  --primary:   #3b6fd4;
  --primary-h: #2a55b0;
  --text:      #1e2a3b;
  --muted:     #6b7a99;
  --radius:    10px;
  --font:      'Segoe UI', system-ui, sans-serif;
  --mono:      'Cascadia Code', 'Fira Mono', 'Consolas', monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; font-family: var(--font); background: var(--bg); color: var(--text); overflow: hidden; }

/* ════════════════════════════════
   LAYOUT SHELLS
════════════════════════════════ */
/* survey view fills viewport */
#survey-view {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  overflow: hidden;
}
#survey-container { flex: 1; overflow-y: auto; }

/* config panel fills viewport */
#config-panel {
  position: absolute; inset: 0;
  display: none; flex-direction: column;
  background: var(--surface);
  overflow: hidden;
}

/* ════════════════════════════════
   EMPTY / SUCCESS STATES
════════════════════════════════ */
.empty-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 100%; gap: 10px; color: var(--muted); text-align: center; padding: 32px;
}
.empty-state .es-icon { font-size: 40px; }
.empty-state h2 { font-size: 16px; color: var(--text); }
.empty-state p  { font-size: 13px; line-height: 1.6; max-width: 340px; }

#success-screen {
  position: absolute; inset: 0;
  display: none; flex-direction: column; align-items: center; justify-content: center;
  gap: 12px; text-align: center; padding: 32px;
  background: var(--bg);
  z-index: 10;
}
.success-check {
  width: 64px; height: 64px; border-radius: 50%; background: #dcfce7;
  display: flex; align-items: center; justify-content: center; font-size: 32px;
  animation: pop .4s cubic-bezier(.36,.07,.19,.97) both;
}
@keyframes pop { 0%{ transform:scale(0) } 70%{ transform:scale(1.15) } 100%{ transform:scale(1) } }
#success-screen h2 { font-size: 20px; color: var(--text); }
#success-screen p  { font-size: 13px; color: var(--muted); }
.btn-primary {
  padding: 9px 22px; background: var(--primary); color: #fff; border: none;
  border-radius: 7px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background .2s;
}
.btn-primary:hover { background: var(--primary-h); }
.btn-primary:disabled { opacity: .45; cursor: not-allowed; }

/* ════════════════════════════════
   CONFIG PANEL LAYOUT
════════════════════════════════ */
.cfg-header {
  padding: 14px 18px 12px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: baseline; gap: 8px;
}
.cfg-header h1 { font-size: 15px; font-weight: 700; color: var(--text); }
.cfg-header .sub { font-size: 11px; color: var(--muted); }

.cfg-body {
  flex: 1; overflow-y: auto; padding: 18px;
  display: flex; flex-direction: column; gap: 20px;
}

.cfg-section > label {
  display: block; font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .6px; color: var(--muted); margin-bottom: 8px;
}

/* ── theme grid ── */
.theme-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 8px;
}
.theme-card {
  border: 2px solid var(--border); border-radius: 8px; padding: 10px 12px;
  cursor: pointer; background: #fafbfd;
  transition: border-color .15s, background .15s;
}
.theme-card:hover  { border-color: var(--primary); background: #f0f4ff; }
.theme-card.active { border-color: var(--primary); background: #eef3ff; }
.tc-swatch { height: 6px; border-radius: 3px; margin-bottom: 8px; }
.tc-name   { font-size: 12px; font-weight: 600; color: var(--text); }
.tc-desc   { font-size: 11px; color: var(--muted); margin-top: 2px; }

/* ── JSON editor ── */
.json-wrap {
  border: 1px solid var(--border); border-radius: 8px; overflow: hidden;
  background: #1a1f2e; display: flex; flex-direction: column;
}
.json-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 6px 10px; background: #252b3b; border-bottom: 1px solid #353d52;
}
.json-toolbar-label { font-size: 11px; color: #7a8aaa; font-family: var(--mono); }
.btn-group { display: flex; gap: 6px; }
.btn-icon {
  background: none; border: 1px solid #353d52; color: #9aaac8;
  border-radius: 5px; padding: 3px 9px; font-size: 11px; cursor: pointer;
  display: inline-flex; align-items: center; gap: 4px;
  transition: background .15s, color .15s;
}
.btn-icon:hover { background: #353d52; color: #e0e8ff; }

#json-editor {
  width: 100%; min-height: 260px; max-height: 360px;
  padding: 14px; font-family: var(--mono); font-size: 12px; line-height: 1.6;
  color: #c8d5f0; background: transparent; border: none; outline: none;
  resize: vertical; tab-size: 2; white-space: pre; overflow-wrap: normal; overflow-x: auto;
}
#json-editor::placeholder { color: #455069; }

#json-status {
  font-size: 11px; padding: 5px 12px;
  background: #1e2536; color: #5a7ab0; min-height: 26px; transition: color .2s;
  font-family: var(--mono);
}
#json-status.valid   { color: #4ade80; }
#json-status.invalid { color: #f87171; }

/* ── footer ── */
.cfg-footer {
  padding: 12px 18px; border-top: 1px solid var(--border);
  display: flex; justify-content: flex-end; gap: 10px; background: var(--surface);
}
.btn-secondary {
  padding: 9px 18px; border: 1px solid var(--border); background: var(--surface);
  color: var(--text); border-radius: 7px; font-size: 13px; font-weight: 600;
  cursor: pointer; transition: background .15s;
}
.btn-secondary:hover { background: var(--bg); }

/* ════════════════════════════════
   TOAST
════════════════════════════════ */
#toast {
  position: fixed; bottom: 16px; left: 50%;
  transform: translateX(-50%) translateY(60px);
  background: #1e2a3b; color: #fff; padding: 9px 18px;
  border-radius: 8px; font-size: 13px; opacity: 0;
  transition: transform .25s, opacity .25s;
  pointer-events: none; z-index: 9999; max-width: 88vw; white-space: pre-wrap;
}
#toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

/* ════════════════════════════════
   SURVEYJS fit
════════════════════════════════ */
.sd-root-modern { background: transparent !important; }
.sd-container-modern { max-width: 100% !important; }
  </style>
</head>
<body>

<!-- ══════════ SURVEY VIEW ══════════ -->
<div id="survey-view">
  <div id="survey-container">
    <div class="empty-state" id="empty-state">
      <span class="es-icon">📋</span>
      <h2>Aucun formulaire configuré</h2>
      <p>Ouvrez la configuration via le menu ⋮ de la section Grist<br>
         (<em>Ouvrir la configuration</em>) pour coller votre JSON SurveyJS.</p>
    </div>
  </div>
</div>

<!-- ══════════ SUCCESS OVERLAY ══════════ -->
<div id="success-screen">
  <div class="success-check">✓</div>
  <h2>Réponse enregistrée !</h2>
  <p id="success-msg">Les données ont été ajoutées à la table liée.</p>
  <button class="btn-primary" id="btn-new-response">+ Nouvelle réponse</button>
</div>

<!-- ══════════ CONFIG PANEL ══════════ -->
<div id="config-panel">

  <div class="cfg-header">
    <h1>Configuration</h1>
    <span class="sub">SurveyJS × Grist</span>
  </div>

  <div class="cfg-body">

    <!-- Theme -->
    <div class="cfg-section">
      <label>Thème SurveyJS</label>
      <div class="theme-grid" id="theme-grid"></div>
    </div>

    <!-- JSON editor -->
    <div class="cfg-section" style="flex:1;display:flex;flex-direction:column;">
      <label>JSON du formulaire</label>
      <div class="json-wrap" style="flex:1;">
        <div class="json-toolbar">
          <span class="json-toolbar-label">survey.json</span>
          <div class="btn-group">
            <button class="btn-icon" id="btn-format">⇌ Formater</button>
            <button class="btn-icon" id="btn-clear">✕ Vider</button>
          </div>
        </div>
        <textarea id="json-editor" spellcheck="false"
          placeholder='{\n  "title": "Mon formulaire",\n  "elements": []\n}'></textarea>
        <div id="json-status">En attente de saisie…</div>
      </div>
    </div>

  </div><!-- /cfg-body -->

  <div class="cfg-footer">
    <button class="btn-secondary" id="btn-cancel">Annuler</button>
    <button class="btn-primary"   id="btn-save" disabled>Enregistrer</button>
  </div>

</div><!-- /config-panel -->

<!-- TOAST -->
<div id="toast" role="alert"></div>

<!-- ══════════════════════════════════════════════════
     SCRIPT
══════════════════════════════════════════════════ -->
<script>
'use strict';

/* ───────────────────────────────────────
   THEME CATALOGUE
─────────────────────────────────────── */
const THEMES = [
  { id: 'default',          label: 'Default',       desc: 'Standard',         swatch: 'linear-gradient(90deg,#19b394,#1ca8b5)' },
  { id: 'sharp',            label: 'Sharp',          desc: 'Angles nets',      swatch: 'linear-gradient(90deg,#1ab394,#3d9c96)' },
  { id: 'borderless',       label: 'Borderless',     desc: 'Sans bordures',    swatch: 'linear-gradient(90deg,#19b394,#a5d6d3)' },
  { id: 'flat',             label: 'Flat',           desc: 'Aplats',           swatch: 'linear-gradient(90deg,#19b394,#70b8b4)' },
  { id: 'doubleborder',     label: 'Double Border',  desc: 'Double contour',   swatch: 'linear-gradient(90deg,#19b394,#0d6f60)' },
  { id: 'layered',          label: 'Layered',        desc: 'En couches',       swatch: 'linear-gradient(90deg,#2e4de0,#7b93f8)' },
  { id: 'solid',            label: 'Solid',          desc: 'Plein',            swatch: 'linear-gradient(90deg,#3d4fb5,#5d6cc8)' },
  { id: 'threedimensional', label: '3D',             desc: 'Relief',           swatch: 'linear-gradient(90deg,#555,#888)' },
  { id: 'contrast',         label: 'Contrast',       desc: 'Haut contraste',   swatch: 'linear-gradient(90deg,#111,#444)' },
];

/* ───────────────────────────────────────
   STATE
─────────────────────────────────────── */
const $ = id => document.getElementById(id);
let surveyInstance = null;
let currentOptions = { theme: 'default', formJson: '' };
let isConfigOpen   = false;
let linkedTableId  = null;   // resolved via grist.selectedTable.getTableId()

/* ───────────────────────────────────────
   TOAST
─────────────────────────────────────── */
function toast(msg, ms = 3500) {
  const el = $('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), ms);
}

/* ───────────────────────────────────────
   VIEW SWITCHING
─────────────────────────────────────── */
function openSurveyView() {
  $('config-panel').style.display = 'none';
  $('survey-view').style.display  = 'flex';
  isConfigOpen = false;
}

function openConfigPanel() {
  $('survey-view').style.display  = 'none';
  $('config-panel').style.display = 'flex';
  isConfigOpen = true;
  loadOptionsIntoEditor(currentOptions);
}

/* ───────────────────────────────────────
   THEME GRID
─────────────────────────────────────── */
function buildThemeGrid(selected) {
  const grid = $('theme-grid');
  grid.innerHTML = '';
  THEMES.forEach(t => {
    const card = document.createElement('div');
    card.className = 'theme-card' + (t.id === selected ? ' active' : '');
    card.dataset.id = t.id;
    card.innerHTML =
      `<div class="tc-swatch" style="background:${t.swatch}"></div>` +
      `<div class="tc-name">${t.label}</div>` +
      `<div class="tc-desc">${t.desc}</div>`;
    card.addEventListener('click', () => {
      grid.querySelectorAll('.theme-card').forEach(c => c.classList.remove('active'));
      card.classList.add('active');
    });
    grid.appendChild(card);
  });
}

function selectedTheme() {
  const a = $('theme-grid').querySelector('.theme-card.active');
  return a ? a.dataset.id : 'default';
}

/* ───────────────────────────────────────
   JSON EDITOR
─────────────────────────────────────── */
const editor   = $('json-editor');
const statusEl = $('json-status');
const saveBtn  = $('btn-save');

function validateJson(raw) {
  if (!raw.trim()) {
    statusEl.textContent = 'En attente de saisie…';
    statusEl.className   = '';
    saveBtn.disabled     = true;
    return false;
  }
  try {
    JSON.parse(raw);
    statusEl.textContent = '✓ JSON valide';
    statusEl.className   = 'valid';
    saveBtn.disabled     = false;
    return true;
  } catch(e) {
    statusEl.textContent = '✗ ' + e.message;
    statusEl.className   = 'invalid';
    saveBtn.disabled     = true;
    return false;
  }
}

editor.addEventListener('input', () => validateJson(editor.value));

$('btn-format').addEventListener('click', () => {
  try {
    editor.value = JSON.stringify(JSON.parse(editor.value), null, 2);
    validateJson(editor.value);
  } catch { toast('JSON invalide, impossible de formater.'); }
});

$('btn-clear').addEventListener('click', () => { editor.value = ''; validateJson(''); });

// Tab → 2 spaces inside textarea
editor.addEventListener('keydown', e => {
  if (e.key !== 'Tab') return;
  e.preventDefault();
  const s = editor.selectionStart;
  editor.value = editor.value.slice(0, s) + '  ' + editor.value.slice(editor.selectionEnd);
  editor.selectionStart = editor.selectionEnd = s + 2;
});

function loadOptionsIntoEditor(opts) {
  buildThemeGrid(opts.theme || 'default');
  try {
    editor.value = opts.formJson
      ? JSON.stringify(JSON.parse(opts.formJson), null, 2)
      : '';
  } catch { editor.value = opts.formJson || ''; }
  validateJson(editor.value);
}

/* ───────────────────────────────────────
   SAVE CONFIG
─────────────────────────────────────── */
$('btn-save').addEventListener('click', async () => {
  if (!validateJson(editor.value)) return;
  const newOpts = { theme: selectedTheme(), formJson: editor.value.trim() };
  try {
    await grist.setOptions(newOpts);
    currentOptions = newOpts;
    openSurveyView();
    buildSurvey(newOpts.formJson, newOpts.theme);
    toast('✓ Configuration enregistrée');
  } catch(e) { toast('Erreur sauvegarde : ' + (e.message || e)); }
});

$('btn-cancel').addEventListener('click', () => {
  openSurveyView();
  // Rebuild survey with current saved options (not unsaved editor state)
  if (currentOptions.formJson) buildSurvey(currentOptions.formJson, currentOptions.theme);
});

/* ───────────────────────────────────────
   BUILD / RENDER SURVEY
─────────────────────────────────────── */
function applyTheme(themeId) {
  try {
    if (Survey && Survey.StylesManager) Survey.StylesManager.applyTheme(themeId);
  } catch(e) {}
}

function buildSurvey(jsonDef, themeId = 'default') {
  // Cleanup previous instance
  if (surveyInstance) { try { surveyInstance.dispose?.(); } catch(e) {} surveyInstance = null; }
  const container = $('survey-container');
  container.innerHTML = '';
  $('success-screen').style.display = 'none';

  if (!jsonDef || !jsonDef.trim()) {
    container.innerHTML = `
      <div class="empty-state">
        <span class="es-icon">📋</span>
        <h2>Aucun formulaire configuré</h2>
        <p>Ouvrez la configuration via le menu ⋮ → <em>Ouvrir la configuration</em>.</p>
      </div>`;
    return;
  }

  let parsed;
  try { parsed = JSON.parse(jsonDef); }
  catch(e) {
    container.innerHTML = `
      <div class="empty-state">
        <span class="es-icon">⚠️</span>
        <h2>JSON invalide</h2><p>${e.message}</p>
      </div>`;
    return;
  }

  applyTheme(themeId);
  surveyInstance = new Survey.Model(parsed);
  surveyInstance.locale = 'fr';
  surveyInstance.onComplete.add(async (sender) => saveResults(sender.data));
  surveyInstance.render(container);
}

/* ───────────────────────────────────────
   SAVE RESULTS → linked table
─────────────────────────────────────── */
async function saveResults(data) {
  // Resolve the linked table ID if not yet known
  if (!linkedTableId) {
    try {
      if (grist.selectedTable) {
        linkedTableId = await grist.selectedTable.getTableId();
      }
    } catch(e) {}
  }

  if (!linkedTableId) {
    toast('⚠️ Impossible de détecter la table liée.\nAssurez-vous que le widget est lié à une table via "Sélectionner des données".');
    // Rebuild so user can try again
    buildSurvey(currentOptions.formJson, currentOptions.theme);
    return;
  }

  try {
    await grist.docApi.applyUserActions([
      ['AddRecord', linkedTableId, null, flattenData(data)]
    ]);
    $('success-msg').textContent = `Réponse enregistrée dans « ${linkedTableId} ».`;
    $('success-screen').style.display = 'flex';
  } catch(e) {
    toast('❌ Erreur enregistrement : ' + (e.message || e));
    buildSurvey(currentOptions.formJson, currentOptions.theme);
  }
}

function flattenData(data) {
  const out = {};
  for (const [k, v] of Object.entries(data))
    out[k] = (v !== null && typeof v === 'object') ? JSON.stringify(v) : v;
  return out;
}

/* ───────────────────────────────────────
   NEW RESPONSE
─────────────────────────────────────── */
$('btn-new-response').addEventListener('click', () => {
  $('success-screen').style.display = 'none';
  buildSurvey(currentOptions.formJson, currentOptions.theme);
});

/* ───────────────────────────────────────
   GRIST INTEGRATION
─────────────────────────────────────── */
grist.ready({
  requiredAccess: 'full',
  // No column mappings – JSON stored in widget options, target = linked table
  onEditOptions() {
    // Called when user clicks "Ouvrir la configuration" in Grist section menu
    openConfigPanel();
  }
});

// Called once on load (and whenever options are saved/reverted)
grist.onOptions(function(options /*, interaction */) {
  if (options) {
    currentOptions = {
      theme:    options.theme    || 'default',
      formJson: options.formJson || ''
    };
  }
  if (!isConfigOpen) {
    openSurveyView();
    buildSurvey(currentOptions.formJson, currentOptions.theme);
  }
});

// Grab the table ID from the widget's data source
grist.onRecords(async function(records /*, mappings */) {
  try {
    if (grist.selectedTable) {
      linkedTableId = await grist.selectedTable.getTableId();
    }
  } catch(e) {}
});
</script>
</body>
</html>
